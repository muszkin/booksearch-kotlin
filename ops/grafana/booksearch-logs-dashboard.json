{
  "title": "BookSearch — Logs",
  "uid": "booksearch-logs",
  "tags": ["booksearch", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "loki",
        "current": { "selected": false, "text": "Loki", "value": "Loki" },
        "hide": 0
      },
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${datasource}" },
        "query": "label_values({stack=\"booksearch\"}, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "level",
        "type": "custom",
        "query": "INFO,WARN,ERROR,DEBUG",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Error rate (5m)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({stack=\"booksearch\",job=~\"$job\"} |= \"ERROR\" [5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 } ] } }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warn rate (5m)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({stack=\"booksearch\",job=~\"$job\"} |= \"WARN\" [5m]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Backend req/s (5m)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({stack=\"booksearch\",job=\"booksearch-backend\"} |= \"x-request-id\" [5m]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Refresh rotations/h",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({stack=\"booksearch\",job=\"booksearch-backend\"} |~ \"Refresh token rotated|BOOK_DELIVERED\" [1h]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Log volume by level",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (level) (count_over_time({stack=\"booksearch\",job=~\"$job\"} | json | level=~\".+\" [1m]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Errors over time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (count_over_time({stack=\"booksearch\",job=~\"$job\"} |= \"ERROR\" [1m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Live logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{stack=\"booksearch\",job=~\"$job\"}"
        }
      ]
    }
  ]
}
