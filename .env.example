# =============================================================================
# BookSearch v2 — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# Lines starting with # are comments. Uncomment and change as needed.

# --- Server ---
SERVER_PORT=8080

# --- Database ---
DATABASE_PATH=./data/booksearch.db

# --- JWT Authentication ---
# IMPORTANT: Change this to a random string in production (min 32 characters).
JWT_SECRET=dev-secret-change-in-production
JWT_ISSUER=booksearch
JWT_AUDIENCE=booksearch-users

# --- Scraper / FlareSolverr ---
SOLVEARR_URL=http://flaresolverr:8191
MAX_CONCURRENT_DOWNLOADS=2
DATA_PATH=./data/library

# --- Anna's Archive Mirrors ---
# Comma-separated list of known mirror domains (checked and rotated automatically).
MIRROR_DOMAINS=annas-archive.gd,annas-archive.pk,annas-archive.gl,annas-archive.li,annas-archive.se,annas-archive.gs

# --- SMTP (system emails: password reset links, notifications) ---
# For development Mailpit catches all outgoing mail on port 1025.
# For production point to your real SMTP server.
SMTP_HOST=mailpit
SMTP_PORT=1025

# --- FlareSolverr log level ---
FLARESOLVERR_LOG_LEVEL=info

# --- Mailpit ports (development only) ---
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
